# Hugging Face token (required for pyannote models)
# Accept terms at https://huggingface.co/pyannote/speaker-diarization-community-1
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pipeline model (default: community-1 — best open-source accuracy)
SPEAKER_SEP_PIPELINE=pyannote/speaker-diarization-community-1

# Device: auto | cuda | cpu
SPEAKER_SEP_DEVICE=auto

# Streaming: window length and step in seconds
SPEAKER_SEP_STREAM_WINDOW_SEC=10.0
SPEAKER_SEP_STREAM_STEP_SEC=0.5
